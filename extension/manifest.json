{
  "manifest_version": 3,
  "name": "Super Admin 采集助手",
  "version": "0.1.0",
  "description": "一键采集当前网页的 Cookie 和 localStorage 到 Super Admin 后台",
  "key": "",
  "permissions": ["activeTab", "storage", "cookies", "scripting"],
  "externally_connectable": {
    "matches": [
      "http://localhost:*/*",
      "http://127.0.0.1:*/*",
      "http://8.130.118.128/*"
    ]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Super Admin - 采集当前页"
  },
  "background": {
    "service_worker": "service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"]
    }
  ]
}
